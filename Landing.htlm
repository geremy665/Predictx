<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=5.0">
<title>EDGE Scanner — Intelligence Algorithmique</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════
   TOKENS
══════════════════════════════════════ */
*{margin:0;padding:0;box-sizing:border-box;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;}
:root{
  /* Backgrounds */
  --bg:#09090F;
  --surface:#0F0F1A;
  --raised:#141422;
  --lifted:#1A1A2E;
  /* Violet electric */
  --vio:#7C3AED;
  --vio2:#9F5FFF;
  --vio3:#C084FC;
  --vio4:#EDE9FE;
  --vioglow:rgba(124,58,237,.5);
  /* Neutrals */
  --white:#FAFAFA;
  --grey1:#E4E4E7;
  --grey2:#A1A1AA;
  --grey3:#52525B;
  --grey4:#27272A;
  --grey5:#18181B;
  /* Borders */
  --border:rgba(124,58,237,.2);
  --border2:rgba(255,255,255,.06);
  --border3:rgba(255,255,255,.03);
  /* Fonts */
  --fi:'Inter',sans-serif;
  --fm:'JetBrains Mono',monospace;
}
html,body{background:var(--bg);color:var(--white);font-family:var(--fi);overflow-x:hidden;scroll-behavior:smooth;cursor:none;}
::selection{background:rgba(124,58,237,.3);}
::-webkit-scrollbar{width:2px;}
::-webkit-scrollbar-thumb{background:var(--vio);border-radius:1px;}

/* ══════════════════════════════════════
   CURSOR
══════════════════════════════════════ */
#cur-ring{position:fixed;width:22px;height:22px;border:1px solid rgba(124,58,237,.6);border-radius:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:9998;transition:all .12s cubic-bezier(.4,0,.2,1);}
#cur-dot{position:fixed;width:4px;height:4px;background:var(--vio2);border-radius:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:9999;box-shadow:0 0 6px var(--vio2);}

/* ══════════════════════════════════════
   AMBIENT CANVAS
══════════════════════════════════════ */
#canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}

/* ══════════════════════════════════════
   NAV
══════════════════════════════════════ */
.nav{position:fixed;top:0;inset-x:0;z-index:900;height:56px;display:flex;align-items:center;padding:0 40px;background:rgba(9,9,15,.85);border-bottom:1px solid var(--border3);backdrop-filter:blur(48px);}
@media(max-width:768px){.nav{padding:0 20px;}}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.nav-bolt{width:28px;height:28px;background:var(--vio);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 0 16px rgba(124,58,237,.5);flex-shrink:0;}
.nav-name{font-family:var(--fi);font-size:16px;font-weight:700;color:var(--white);letter-spacing:-.02em;}
.nav-name span{color:var(--vio3);}
.nav-badge{font-family:var(--fm);font-size:10px;color:var(--vio3);background:rgba(124,58,237,.12);border:1px solid rgba(124,58,237,.22);border-radius:5px;padding:2px 8px;letter-spacing:.06em;margin-left:2px;}
.nav-links{margin-left:auto;display:flex;align-items:center;gap:1px;}
.nl{font-size:13px;color:var(--grey2);padding:6px 14px;border-radius:7px;cursor:none;transition:.14s;background:none;border:none;font-family:var(--fi);font-weight:400;letter-spacing:-.01em;}
.nl:hover{color:var(--white);}
.nl.on{color:var(--vio3);}
.nav-cta{margin-left:8px;padding:7px 20px;background:var(--vio);color:#fff;font-size:13px;font-weight:600;border-radius:8px;cursor:none;border:none;font-family:var(--fi);transition:.18s;letter-spacing:-.01em;box-shadow:0 0 20px rgba(124,58,237,.35);}
.nav-cta:hover{background:var(--vio2);box-shadow:0 0 36px rgba(124,58,237,.55);transform:translateY(-1px);}
.nav-burger{display:none;flex-direction:column;gap:4px;width:32px;height:32px;background:var(--surface);border:1px solid var(--border2);border-radius:7px;align-items:center;justify-content:center;margin-left:auto;cursor:none;}
.nav-burger span{width:12px;height:1.5px;background:var(--grey2);border-radius:1px;display:block;}
@media(max-width:768px){.nl,.nav-cta{display:none;}.nav-burger{display:flex;}}

/* ══════════════════════════════════════
   HERO
══════════════════════════════════════ */
.hero{position:relative;z-index:2;min-height:100vh;display:grid;grid-template-rows:1fr auto;padding:56px 0 0;overflow:hidden;}

/* Subtle grid */
.hero-grid{position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(124,58,237,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(124,58,237,.04) 1px,transparent 1px);background-size:72px 72px;mask-image:radial-gradient(ellipse 80% 60% at 50% 30%,black,transparent);}

/* Glows — restrained */
.hero-glow{position:absolute;pointer-events:none;border-radius:50%;filter:blur(100px);}
.hg-center{top:-10%;left:50%;transform:translateX(-50%);width:800px;height:600px;background:radial-gradient(ellipse,rgba(124,58,237,.12),transparent 65%);}
.hg-left{top:40%;left:-8%;width:400px;height:400px;background:radial-gradient(ellipse,rgba(124,58,237,.06),transparent 65%);}
.hg-right{bottom:-10%;right:-8%;width:500px;height:400px;background:radial-gradient(ellipse,rgba(167,95,255,.08),transparent 65%);}

.hero-inner{position:relative;z-index:3;max-width:1080px;margin:0 auto;width:100%;padding:88px 40px 0;}
@media(max-width:768px){.hero-inner{padding:80px 20px 0;}}

/* Eyebrow */
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;margin-bottom:36px;}
.eyebrow-dot{width:6px;height:6px;border-radius:50%;background:var(--vio2);box-shadow:0 0 8px var(--vio),0 0 16px rgba(124,58,237,.4);animation:pulse-dot 2s infinite;}
.eyebrow-text{font-family:var(--fm);font-size:11px;color:var(--vio3);letter-spacing:.18em;text-transform:uppercase;}

/* Title — Inter 900, clean & impactful */
.hero-title{font-family:var(--fi);font-weight:900;font-size:clamp(48px,8.5vw,108px);line-height:.92;letter-spacing:-.04em;margin-bottom:28px;}
.ht1{display:block;color:var(--white);animation:up .8s ease both;}
.ht2{display:block;animation:up .8s .12s ease both;}
.ht2 span{background:linear-gradient(135deg,var(--vio2) 0%,var(--vio3) 50%,#E879F9 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.ht3{display:block;color:var(--grey2);font-weight:400;font-size:clamp(36px,5.5vw,72px);letter-spacing:-.03em;animation:up .8s .24s ease both;}

/* Desc */
.hero-desc{font-size:clamp(15px,1.8vw,18px);color:var(--grey2);line-height:1.85;max-width:540px;margin-bottom:44px;font-weight:400;animation:up .8s .36s ease both;letter-spacing:-.01em;}
.hero-desc strong{color:var(--white);font-weight:600;}

/* Actions */
.hero-actions{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:64px;animation:up .8s .48s ease both;}
.btn-primary{height:52px;padding:0 28px;background:var(--vio);color:#fff;font-family:var(--fi);font-size:14px;font-weight:600;border:none;border-radius:10px;cursor:none;display:inline-flex;align-items:center;gap:9px;letter-spacing:-.01em;transition:.18s;box-shadow:0 0 0 0 rgba(124,58,237,.4);}
.btn-primary:hover{background:var(--vio2);transform:translateY(-2px);box-shadow:0 8px 32px rgba(124,58,237,.45);}
.btn-ghost{height:52px;padding:0 24px;background:transparent;border:1px solid var(--border2);border-radius:10px;color:var(--grey2);font-family:var(--fi);font-size:14px;cursor:none;letter-spacing:-.01em;transition:.18s;}
.btn-ghost:hover{border-color:rgba(124,58,237,.35);color:var(--white);}

/* Metrics */
.hero-metrics{display:flex;align-items:center;gap:36px;flex-wrap:wrap;animation:up .8s .58s ease both;}
.metric{display:flex;align-items:baseline;gap:9px;}
.metric-val{font-family:var(--fi);font-size:32px;font-weight:800;color:var(--white);letter-spacing:-.03em;}
.metric-label{font-family:var(--fm);font-size:9px;color:var(--grey3);text-transform:uppercase;letter-spacing:.14em;line-height:1.5;}
.metric-div{width:1px;height:28px;background:var(--border2);}

/* ══════════════════════════════════════
   LIVE MATCH BAR
══════════════════════════════════════ */
.match-bar{position:relative;z-index:3;border-top:1px solid var(--border3);margin-top:64px;}
.mbar-inner{max-width:1080px;margin:0 auto;display:flex;align-items:stretch;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.mbar-inner::-webkit-scrollbar{display:none;}

.mbar-label{display:flex;align-items:center;gap:8px;padding:0 24px;flex-shrink:0;border-right:1px solid var(--border3);}
.mbar-label-dot{width:5px;height:5px;border-radius:50%;background:var(--vio2);box-shadow:0 0 8px var(--vio);animation:pulse-dot 1.6s infinite;}
.mbar-label-txt{font-family:var(--fm);font-size:9px;color:var(--vio3);letter-spacing:.18em;text-transform:uppercase;white-space:nowrap;}

.mbar-item{display:flex;align-items:center;gap:16px;padding:14px 22px;border-right:1px solid var(--border3);cursor:none;transition:.16s;flex-shrink:0;position:relative;}
.mbar-item:hover{background:rgba(124,58,237,.04);}
.mbar-item.mbar-live::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--vio),var(--vio3));animation:flow 3s linear infinite;background-size:200% 100%;}

.mbar-flag{width:18px;height:11px;border-radius:2px;display:inline-flex;align-items:center;justify-content:center;font-family:var(--fm);font-size:5px;font-weight:700;flex-shrink:0;}
.fFR{background:#002395;color:#fff;}.fES{background:#c60b1e;color:#ffc400;}.fENG{background:#CF142B;color:#fff;}.fUCL{background:#071d5e;color:#c8a900;}.fIT{background:#009246;color:#fff;}.fDE{background:#111;color:#FFCD00;}

.mbar-teams{display:flex;flex-direction:column;gap:2px;}
.mbar-home{font-family:var(--fi);font-size:12px;font-weight:600;color:var(--white);white-space:nowrap;letter-spacing:-.01em;}
.mbar-away{font-family:var(--fi);font-size:11px;font-weight:400;color:var(--grey2);white-space:nowrap;}
.mbar-score{font-family:var(--fi);font-size:16px;font-weight:800;color:var(--vio3);letter-spacing:-.02em;}
.mbar-odds{display:flex;flex-direction:column;gap:2px;align-items:flex-end;}
.mbar-odd{font-family:var(--fm);font-size:11px;color:var(--grey3);}
.mbar-odd.mbar-val{color:var(--vio3);font-weight:500;}
.mbar-edge{font-family:var(--fm);font-size:9px;color:var(--vio2);letter-spacing:.04em;}
.mbar-lg{font-family:var(--fm);font-size:8px;color:var(--grey3);white-space:nowrap;margin-top:1px;}
.mbar-all{display:flex;align-items:center;gap:8px;padding:0 22px;flex-shrink:0;cursor:none;transition:.14s;}
.mbar-all:hover .mbar-all-txt{color:var(--vio3);}
.mbar-all-txt{font-family:var(--fm);font-size:9px;color:var(--grey3);letter-spacing:.12em;text-transform:uppercase;transition:.14s;}

/* ══════════════════════════════════════
   SECTIONS SHELL
══════════════════════════════════════ */
.section{position:relative;z-index:2;}
.si{max-width:1080px;margin:0 auto;padding:96px 40px;}
@media(max-width:768px){.si{padding:72px 20px;}}
.s-tag{font-family:var(--fm);font-size:9px;color:var(--vio3);letter-spacing:.24em;text-transform:uppercase;margin-bottom:18px;text-align:center;display:flex;align-items:center;gap:12px;justify-content:center;}
.s-tag::before,.s-tag::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(124,58,237,.3));}
.s-tag::after{background:linear-gradient(270deg,transparent,rgba(124,58,237,.3));}
.s-title{font-family:var(--fi);font-weight:800;font-size:clamp(34px,5vw,60px);letter-spacing:-.04em;line-height:.92;margin-bottom:16px;text-align:center;color:var(--white);}
.s-title em{font-style:normal;background:linear-gradient(135deg,var(--vio2),var(--vio3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.s-desc{font-size:15px;color:var(--grey2);line-height:1.85;text-align:center;max-width:500px;margin:0 auto;letter-spacing:-.01em;}

/* ══════════════════════════════════════
   HOW IT WORKS
══════════════════════════════════════ */
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border3);border:1px solid var(--border3);border-radius:20px;overflow:hidden;margin-top:48px;}
@media(max-width:700px){.steps{grid-template-columns:1fr;}}
.step{background:var(--surface);padding:32px 28px;transition:.2s;cursor:none;position:relative;overflow:hidden;}
.step:hover{background:var(--raised);}
.step::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--vio),var(--vio3));opacity:0;transition:.2s;}
.step:hover::after{opacity:1;}
.step-num{font-family:var(--fm);font-size:52px;color:rgba(124,58,237,.08);line-height:1;margin-bottom:16px;letter-spacing:-.02em;}
.step-icon{font-size:22px;margin-bottom:14px;}
.step-title{font-family:var(--fi);font-size:17px;font-weight:700;color:var(--white);margin-bottom:8px;letter-spacing:-.02em;}
.step-desc{font-family:var(--fm);font-size:9px;color:var(--grey3);line-height:1.9;}

/* ══════════════════════════════════════
   MATCH CARDS
══════════════════════════════════════ */
.match-section{background:linear-gradient(180deg,transparent,rgba(124,58,237,.03) 50%,transparent);}
.mgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:14px;margin-top:48px;}
@media(max-width:480px){.mgrid{grid-template-columns:1fr;}}

.card{background:var(--surface);border:1px solid var(--border3);border-radius:18px;overflow:hidden;cursor:none;transition:all .22s cubic-bezier(.4,0,.2,1);position:relative;}
.card:hover{transform:translateY(-5px);border-color:var(--border2);}
.card.card-hot{border-color:rgba(124,58,237,.16);}
.card.card-live{border-color:rgba(124,58,237,.28);}
.card.card-hot:hover{box-shadow:0 16px 48px rgba(124,58,237,.14);}
.card.card-live:hover{box-shadow:0 16px 48px rgba(124,58,237,.22);}
.card-inner-glow{position:absolute;inset:0;border-radius:18px;background:radial-gradient(ellipse at 50% 0%,rgba(124,58,237,.07),transparent 55%);opacity:0;transition:.26s;pointer-events:none;}
.card:hover .card-inner-glow{opacity:1;}

.card-topbar{height:2px;}
.ctb-live{background:linear-gradient(90deg,var(--vio),var(--vio3));background-size:200%;animation:flow 3s linear infinite;}
.ctb-hot{background:var(--vio);opacity:.7;}
.ctb-norm{background:var(--border3);}

.card-body{padding:18px;}
.card-hdr{display:flex;align-items:center;gap:7px;margin-bottom:14px;}
.card-lg{font-family:var(--fm);font-size:8px;color:var(--grey3);letter-spacing:.06em;}
.card-time{margin-left:auto;font-family:var(--fm);font-size:11px;color:var(--grey2);font-weight:500;}
.live-pill{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;background:rgba(124,58,237,.12);border:1px solid rgba(124,58,237,.24);border-radius:100px;font-family:var(--fm);font-size:7px;color:var(--vio3);}
.live-pill-dot{width:4px;height:4px;border-radius:50%;background:var(--vio2);animation:pulse-dot 1.3s infinite;}
.val-pill{font-family:var(--fm);font-size:7px;padding:2px 8px;border-radius:5px;background:rgba(124,58,237,.1);color:var(--vio3);border:1px solid rgba(124,58,237,.2);}

.card-teams{display:grid;grid-template-columns:1fr 48px 1fr;align-items:center;gap:6px;margin-bottom:14px;}
.card-home{font-family:var(--fi);font-size:16px;font-weight:700;color:var(--white);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;letter-spacing:-.02em;}
.card-away{font-family:var(--fi);font-size:16px;font-weight:600;color:var(--grey2);text-align:right;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;letter-spacing:-.02em;}
.card-ctr{display:flex;flex-direction:column;align-items:center;gap:3px;}
.card-score{font-family:var(--fi);font-size:18px;font-weight:800;color:var(--vio3);letter-spacing:-.02em;}
.card-vs{font-family:var(--fm);font-size:8px;color:var(--grey3);}
.card-vsep{width:1px;height:9px;background:var(--border2);}

.card-odds{display:grid;grid-template-columns:1fr 1fr 1fr;gap:5px;margin-bottom:12px;}
.odd{background:var(--raised);border:1px solid var(--border3);border-radius:10px;padding:10px 4px;text-align:center;transition:.16s;position:relative;overflow:hidden;}
.odd.odd-v{border-color:rgba(124,58,237,.35);background:rgba(124,58,237,.08);}
.odd.odd-v::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% -30%,rgba(124,58,237,.14),transparent 60%);}
/* Halo — clean single layer */
.odd.odd-v::after{content:'';position:absolute;inset:-1px;border-radius:11px;border:1px solid rgba(124,58,237,.4);box-shadow:0 0 14px rgba(124,58,237,.25),inset 0 0 10px rgba(124,58,237,.05);pointer-events:none;}
.odd-lbl{font-family:var(--fm);font-size:7px;color:var(--grey3);margin-bottom:4px;letter-spacing:.04em;}
.odd-num{font-family:var(--fi);font-size:19px;font-weight:700;color:var(--white);letter-spacing:-.02em;position:relative;}
.odd.odd-v .odd-num{color:var(--vio3);}

.card-foot{display:flex;align-items:center;justify-content:space-between;padding-top:11px;border-top:1px solid var(--border3);}
.card-conf{display:flex;align-items:center;gap:7px;}
.card-conf-n{font-family:var(--fm);font-size:9px;color:var(--grey3);}
.card-conf-bar{width:46px;height:2px;background:var(--raised);border-radius:1px;overflow:hidden;}
.card-conf-fill{height:100%;background:var(--vio);border-radius:1px;opacity:.8;}
.card-edge-tag{font-family:var(--fm);font-size:10px;color:var(--vio3);letter-spacing:.02em;}

/* ══════════════════════════════════════
   ENGINE
══════════════════════════════════════ */
.engine-sec{border-top:1px solid var(--border3);border-bottom:1px solid var(--border3);background:radial-gradient(ellipse at 50% 0%,rgba(124,58,237,.05),transparent 55%);}
.engine-layout{display:grid;grid-template-columns:260px 1fr;gap:56px;align-items:center;margin-top:52px;}
@media(max-width:820px){.engine-layout{grid-template-columns:1fr;gap:44px;}}

/* Orbital */
.orb-wrap{display:flex;align-items:center;justify-content:center;}
.orb{position:relative;width:220px;height:220px;}
.orb-ring{position:absolute;border-radius:50%;border:1px solid;top:50%;left:50%;}
.or1{width:220px;height:220px;margin:-110px 0 0 -110px;border-color:rgba(124,58,237,.12);animation:rot 28s linear infinite;}
.or2{width:162px;height:162px;margin:-81px 0 0 -81px;border-color:rgba(124,58,237,.2);animation:rot 18s linear infinite reverse;}
.or3{width:110px;height:110px;margin:-55px 0 0 -55px;border-color:rgba(124,58,237,.32);animation:rot 11s linear infinite;}
.orb-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:60px;height:60px;background:var(--vio);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px;box-shadow:0 0 24px rgba(124,58,237,.6),0 0 48px rgba(124,58,237,.18);}
.orb-dot{position:absolute;width:7px;height:7px;background:var(--vio2);border-radius:50%;box-shadow:0 0 8px var(--vio);top:50%;left:50%;margin:-3.5px 0 0 -3.5px;}

.algos{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.algo{background:var(--surface);border:1px solid var(--border3);border-radius:12px;padding:14px 16px;transition:.18s;cursor:none;position:relative;overflow:hidden;}
.algo::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--vio);opacity:0;transition:.18s;}
.algo:hover{border-color:var(--border2);background:var(--raised);}
.algo:hover::before{opacity:1;}
.algo-name{font-family:var(--fi);font-size:13px;font-weight:700;color:var(--white);margin-bottom:4px;letter-spacing:-.02em;}
.algo-desc{font-family:var(--fm);font-size:8px;color:var(--grey3);line-height:1.7;}
.algo-tag{font-family:var(--fm);font-size:9px;color:var(--vio3);margin-top:7px;}

/* Confidence */
.conf-box{background:var(--surface);border:1px solid rgba(124,58,237,.18);border-radius:20px;padding:26px 30px;position:relative;overflow:hidden;margin-top:32px;box-shadow:0 0 40px rgba(124,58,237,.06);}
.conf-box::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--vio),var(--vio3));background-size:200%;animation:flow 5s linear infinite;}
.conf-box-glow{position:absolute;inset:0;background:radial-gradient(ellipse at 50% -10%,rgba(124,58,237,.06),transparent 55%);pointer-events:none;}
.conf-row{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px;position:relative;}
.conf-lbl{font-family:var(--fi);font-size:18px;font-weight:700;letter-spacing:-.02em;margin-bottom:6px;}
.conf-sub{font-family:var(--fm);font-size:8.5px;color:var(--grey3);letter-spacing:.08em;line-height:1.8;text-transform:uppercase;}
.conf-num{font-family:var(--fi);font-size:56px;font-weight:900;color:var(--vio3);letter-spacing:-.04em;line-height:1;}
.conf-num-lbl{font-family:var(--fm);font-size:8px;color:var(--grey3);letter-spacing:.1em;text-align:right;margin-top:3px;}
.conf-track{height:8px;background:var(--raised);border-radius:4px;overflow:visible;margin-bottom:16px;}
.conf-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--vio),var(--vio3));position:relative;transition:width 2.6s cubic-bezier(.4,0,.2,1);box-shadow:0 0 18px rgba(124,58,237,.45);}
.conf-fill::after{content:'';position:absolute;right:-2px;top:50%;transform:translateY(-50%);width:16px;height:16px;background:var(--vio2);border-radius:50%;box-shadow:0 0 14px var(--vio),0 0 28px rgba(124,58,237,.5);border:2px solid rgba(255,255,255,.2);animation:pulse-dot 1.8s infinite;}
.conf-foot{display:flex;align-items:center;gap:10px;}
.conf-foot-dot{width:6px;height:6px;border-radius:50%;background:var(--vio2);box-shadow:0 0 8px var(--vio);animation:pulse-dot 2s infinite;flex-shrink:0;}
.conf-foot-txt{font-family:var(--fm);font-size:8.5px;color:var(--grey3);letter-spacing:.05em;line-height:1.8;}

/* ══════════════════════════════════════
   RADAR
══════════════════════════════════════ */
.radar-layout{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;margin-top:52px;}
@media(max-width:820px){.radar-layout{grid-template-columns:1fr;gap:44px;}}
.radar-wrap{display:flex;align-items:center;justify-content:center;}
.radar-wrap canvas{max-width:340px;width:100%;filter:drop-shadow(0 0 24px rgba(124,58,237,.22));}
.reasons{display:flex;flex-direction:column;gap:10px;}
.rsn{background:var(--surface);border:1px solid var(--border3);border-radius:14px;padding:18px 20px;display:flex;gap:14px;align-items:flex-start;cursor:none;transition:.2s;opacity:0;transform:translateX(28px);}
.rsn.in{opacity:1;transform:none;transition:opacity .65s cubic-bezier(.4,0,.2,1),transform .65s cubic-bezier(.4,0,.2,1);}
.rsn:hover{border-color:var(--border2);background:var(--raised);}
.rsn-num{width:34px;height:34px;border-radius:9px;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.2);display:flex;align-items:center;justify-content:center;font-family:var(--fi);font-size:14px;font-weight:800;color:var(--vio3);flex-shrink:0;letter-spacing:-.02em;}
.rsn-title{font-family:var(--fi);font-size:14px;font-weight:700;color:var(--white);margin-bottom:4px;letter-spacing:-.02em;}
.rsn-desc{font-family:var(--fm);font-size:8.5px;color:var(--grey3);line-height:1.9;}

/* ══════════════════════════════════════
   CTA
══════════════════════════════════════ */
.cta-sec{position:relative;z-index:2;overflow:hidden;text-align:center;padding:120px 40px;}
@media(max-width:768px){.cta-sec{padding:88px 20px;}}
.cta-bg1{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:900px;height:600px;background:radial-gradient(ellipse,rgba(124,58,237,.1),transparent 65%);pointer-events:none;border-radius:50%;}
.cta-bg2{position:absolute;top:10%;left:5%;width:300px;height:300px;background:radial-gradient(ellipse,rgba(124,58,237,.07),transparent 65%);pointer-events:none;border-radius:50%;}
.cta-bg3{position:absolute;bottom:5%;right:5%;width:280px;height:280px;background:radial-gradient(ellipse,rgba(167,95,255,.07),transparent 65%);pointer-events:none;border-radius:50%;}
.cta-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(124,58,237,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(124,58,237,.04) 1px,transparent 1px);background-size:72px 72px;mask-image:radial-gradient(ellipse 70% 70% at 50% 50%,black,transparent);pointer-events:none;}
.cta-inner{position:relative;z-index:3;}
.cta-title{font-family:var(--fi);font-weight:900;font-size:clamp(44px,8vw,96px);letter-spacing:-.04em;line-height:.9;margin-bottom:20px;}
.cta-title em{font-style:normal;background:linear-gradient(135deg,var(--vio2),var(--vio3),#E879F9);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.cta-desc{font-size:16px;color:var(--grey2);max-width:480px;margin:0 auto 44px;line-height:1.85;letter-spacing:-.01em;}
.cta-btn{position:relative;display:inline-flex;align-items:center;gap:10px;height:60px;padding:0 44px;background:var(--vio);border:none;border-radius:14px;cursor:none;font-family:var(--fi);font-size:15px;font-weight:700;color:#fff;letter-spacing:-.01em;transition:.22s;box-shadow:0 0 0 0 rgba(124,58,237,.4);overflow:hidden;}
.cta-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.14),transparent);opacity:0;transition:.22s;}
.cta-btn:hover{transform:translateY(-3px);box-shadow:0 10px 44px rgba(124,58,237,.5);background:var(--vio2);}
.cta-btn:hover::before{opacity:1;}
.cta-btn span{position:relative;z-index:1;}
.cta-note{font-family:var(--fm);font-size:8px;color:var(--grey3);margin-top:18px;letter-spacing:.1em;line-height:2.2;}

/* FOOTER */
.footer{border-top:1px solid var(--border3);padding:28px 40px;position:relative;z-index:2;}
@media(max-width:768px){.footer{padding:22px 20px;}}
.footer-inner{max-width:1080px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;}
.footer-logo{font-family:var(--fi);font-size:16px;font-weight:700;letter-spacing:-.02em;color:var(--white);}
.footer-logo em{font-style:normal;color:var(--vio3);}
.footer-links{display:flex;gap:20px;}
.footer-link{font-family:var(--fm);font-size:8px;color:var(--grey3);text-decoration:none;letter-spacing:.1em;text-transform:uppercase;transition:.14s;cursor:none;}
.footer-link:hover{color:var(--vio3);}
.footer-copy{font-family:var(--fm);font-size:8px;color:var(--grey4);letter-spacing:.06em;}
@media(max-width:768px){.footer-inner{flex-direction:column;align-items:center;text-align:center;}}

/* ══════════════════════════════════════
   KEYFRAMES
══════════════════════════════════════ */
@keyframes rot{to{transform:rotate(360deg);}}
@keyframes up{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:none;}}
@keyframes flow{0%{background-position:0% 0%;}100%{background-position:200% 0%;}}
@keyframes pulse-dot{0%,100%{opacity:1;}50%{opacity:.3;}}
@keyframes orb-a{0%{transform:rotate(0deg) translateX(80px) rotate(0deg);}100%{transform:rotate(360deg) translateX(80px) rotate(-360deg);}}
@keyframes orb-b{0%{transform:rotate(120deg) translateX(80px) rotate(-120deg);}100%{transform:rotate(480deg) translateX(80px) rotate(-480deg);}}
@keyframes orb-c{0%{transform:rotate(240deg) translateX(80px) rotate(-240deg);}100%{transform:rotate(600deg) translateX(80px) rotate(-600deg);}}
</style>
</head>
<body>

<div id="cur-ring"></div>
<div id="cur-dot"></div>
<canvas id="canvas"></canvas>

<!-- NAV -->
<nav class="nav">
  <a class="nav-logo" href="#">
    <div class="nav-bolt">⚡</div>
    <div class="nav-name">EDGE <span>Scanner</span></div>
    <div class="nav-badge">PRO</div>
  </a>
  <div class="nav-links">
    <button class="nl on">Pronos</button>
    <button class="nl">Value Bets</button>
    <button class="nl">Live</button>
    <button class="nl">Tarifs</button>
    <button class="nav-cta">Connexion</button>
  </div>
  <div class="nav-burger"><span></span><span></span><span></span></div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-glow hg-center"></div>
  <div class="hero-glow hg-left"></div>
  <div class="hero-glow hg-right"></div>
  <div class="hero-inner">
    <div class="hero-eyebrow">
      <div class="eyebrow-dot"></div>
      <span class="eyebrow-text">Moteur actif · 18 ligues · Temps réel</span>
    </div>
    <h1 class="hero-title">
      <span class="ht1">Détectez</span>
      <span class="ht2"><span>l'avantage</span></span>
      <span class="ht3">avant les bookmakers.</span>
    </h1>
    <p class="hero-desc">Un moteur algorithmique de <strong>précision militaire</strong> — Dixon-Coles, Bayésien, Monte Carlo — qui identifie les value bets avec une fiabilité mathématique.</p>
    <div class="hero-actions">
      <button class="btn-primary" onclick="document.getElementById('match-section').scrollIntoView({behavior:'smooth'})">
        <span>⚡</span><span>Scanner les matchs</span>
      </button>
      <button class="btn-ghost" onclick="document.getElementById('engine').scrollIntoView({behavior:'smooth'})">Découvrir le moteur →</button>
    </div>
    <div class="hero-metrics">
      <div class="metric">
        <div class="metric-val" id="m1">0</div>
        <div class="metric-label">Matchs<br>analysés</div>
      </div>
      <div class="metric-div"></div>
      <div class="metric">
        <div class="metric-val" id="m2">0</div>
        <div class="metric-label">Value<br>bets</div>
      </div>
      <div class="metric-div"></div>
      <div class="metric">
        <div class="metric-val" id="m3">0%</div>
        <div class="metric-label">Confiance<br>moyenne</div>
      </div>
      <div class="metric-div"></div>
      <div class="metric">
        <div class="metric-val" id="m4">0%</div>
        <div class="metric-label">Edge<br>moyen</div>
      </div>
    </div>
  </div>

  <!-- LIVE BAR -->
  <div class="match-bar">
    <div class="mbar-inner">
      <div class="mbar-label">
        <div class="mbar-label-dot"></div>
        <span class="mbar-label-txt">Live</span>
      </div>
      <div class="mbar-item mbar-live" onclick="document.getElementById('match-section').scrollIntoView({behavior:'smooth'})">
        <div class="mbar-flag fFR">FR</div>
        <div>
          <div class="mbar-teams"><div class="mbar-home">PSG</div><div class="mbar-away">Monaco</div></div>
          <div class="mbar-lg">Ligue 1 · 78'</div>
        </div>
        <div class="mbar-score">2–1</div>
        <div class="mbar-odds"><div class="mbar-odd mbar-val">1.65</div><div class="mbar-edge">+12.4%</div></div>
      </div>
      <div class="mbar-item" onclick="document.getElementById('match-section').scrollIntoView({behavior:'smooth'})">
        <div class="mbar-flag fENG">ENG</div>
        <div>
          <div class="mbar-teams"><div class="mbar-home">Arsenal</div><div class="mbar-away">Man City</div></div>
          <div class="mbar-lg">Premier League · 21:00</div>
        </div>
        <div class="mbar-odds"><div class="mbar-odd mbar-val">2.70</div><div class="mbar-edge">+5.9%</div></div>
      </div>
      <div class="mbar-item" onclick="document.getElementById('match-section').scrollIntoView({behavior:'smooth'})">
        <div class="mbar-flag fES">ES</div>
        <div>
          <div class="mbar-teams"><div class="mbar-home">Atlético</div><div class="mbar-away">Villarreal</div></div>
          <div class="mbar-lg">La Liga · 20:00</div>
        </div>
        <div class="mbar-odds"><div class="mbar-odd mbar-val">1.88</div><div class="mbar-edge">+6.7%</div></div>
      </div>
      <div class="mbar-item" onclick="document.getElementById('match-section').scrollIntoView({behavior:'smooth'})">
        <div class="mbar-flag fIT">IT</div>
        <div>
          <div class="mbar-teams"><div class="mbar-home">Napoli</div><div class="mbar-away">Juventus</div></div>
          <div class="mbar-lg">Serie A · 20:45</div>
        </div>
        <div class="mbar-odds"><div class="mbar-odd mbar-val">2.10</div><div class="mbar-edge">+7.2%</div></div>
      </div>
      <div class="mbar-item" onclick="document.getElementById('match-section').scrollIntoView({behavior:'smooth'})">
        <div class="mbar-flag fUCL">UCL</div>
        <div>
          <div class="mbar-teams"><div class="mbar-home">Bayern</div><div class="mbar-away">Inter</div></div>
          <div class="mbar-lg">Champions · 21:00</div>
        </div>
        <div class="mbar-odds"><div class="mbar-odd">1.85</div><div class="mbar-edge" style="color:var(--grey3);">—</div></div>
      </div>
      <div class="mbar-all" onclick="document.getElementById('match-section').scrollIntoView({behavior:'smooth'})">
        <span class="mbar-all-txt">Voir tout →</span>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section" id="how">
  <div class="si">
    <div class="s-tag">Comment ça marche</div>
    <h2 class="s-title">3 étapes. <em>1 avantage.</em></h2>
    <p class="s-desc">De la donnée brute à la décision éclairée — le moteur EDGE travaille en permanence pour vous.</p>
    <div class="steps">
      <div class="step"><div class="step-num">01</div><div class="step-icon">📡</div><div class="step-title">Collecte</div><div class="step-desc">xG, cotes, forme, blessures et 9 facteurs contextuels de 18 ligues en temps réel.</div></div>
      <div class="step"><div class="step-num">02</div><div class="step-icon">🧮</div><div class="step-title">Analyse</div><div class="step-desc">Dixon-Coles + Bayesian + Monte Carlo (500 sim.) + Kelly adaptatif calculent la probabilité réelle.</div></div>
      <div class="step"><div class="step-num">03</div><div class="step-icon">⚡</div><div class="step-title">Détection</div><div class="step-desc">Quand la probabilité dépasse la cote implicite du bookmaker, l'edge est confirmé et présenté.</div></div>
    </div>
  </div>
</section>

<!-- MATCHS -->
<section class="section match-section" id="match-section">
  <div class="si">
    <div class="s-tag">Opportunités du jour</div>
    <h2 class="s-title">Value bets <em>confirmés.</em></h2>
    <p class="s-desc">Le halo violet entoure les cotes avec un edge mathématique positif. Uniquement des algorithmes.</p>
    <div class="mgrid" id="mgrid"></div>
    <div style="text-align:center;margin-top:36px;">
      <button class="btn-primary" onclick="runScan()" style="display:inline-flex;">
        <span>⚡</span><span id="scanTxt">Scanner tous les matchs</span>
      </button>
    </div>
  </div>
</section>

<!-- ENGINE -->
<section class="section engine-sec" id="engine">
  <div class="si">
    <div class="s-tag">Le Moteur EDGE</div>
    <h2 class="s-title">Une IA. <em>6 algorithmes.</em></h2>
    <p class="s-desc">Un moteur mathématique de précision — pas un site de pronos classique.</p>
    <div class="engine-layout">
      <div class="orb-wrap">
        <div class="orb">
          <div class="orb-ring or1"></div>
          <div class="orb-ring or2"></div>
          <div class="orb-ring or3"></div>
          <div class="orb-center">⚡</div>
          <div class="orb-dot" style="animation:orb-a 5s linear infinite;"></div>
          <div class="orb-dot" style="animation:orb-b 5s linear infinite;"></div>
          <div class="orb-dot" style="animation:orb-c 5s linear infinite;"></div>
        </div>
      </div>
      <div class="algos">
        <div class="algo"><div class="algo-name">Dixon-Coles</div><div class="algo-desc">Poisson bivarié corrigé pour les scores serrés</div><div class="algo-tag">★ Core</div></div>
        <div class="algo"><div class="algo-name">Bayesian</div><div class="algo-desc">Mise à jour continue avec les données de marché</div><div class="algo-tag">★ Core</div></div>
        <div class="algo"><div class="algo-name">Monte Carlo</div><div class="algo-desc">500 simulations par match pour affiner les probas</div><div class="algo-tag">500 sim.</div></div>
        <div class="algo"><div class="algo-name">Kelly Adaptatif</div><div class="algo-desc">Mise optimale selon l'edge et le bankroll</div><div class="algo-tag">±3.2%</div></div>
        <div class="algo"><div class="algo-name">9 Facteurs</div><div class="algo-desc">Domicile, forme, fatigue, motivation, rotation…</div><div class="algo-tag">Contexte</div></div>
        <div class="algo"><div class="algo-name">18 Ligues</div><div class="algo-desc">Coefficients spécifiques par championnat</div><div class="algo-tag">Europe</div></div>
      </div>
    </div>
    <div class="conf-box">
      <div class="conf-box-glow"></div>
      <div class="conf-row">
        <div>
          <div class="conf-lbl">Niveau de confiance</div>
          <div class="conf-sub">PSG vs Monaco · Victoire PSG<br>Ligue 1 · 21:00 · Paris</div>
        </div>
        <div style="text-align:right;">
          <div class="conf-num" id="cwNum">0%</div>
          <div class="conf-num-lbl">Confiance moteur</div>
        </div>
      </div>
      <div class="conf-track"><div class="conf-fill" id="cwBar" style="width:0%"></div></div>
      <div class="conf-foot">
        <div class="conf-foot-dot"></div>
        <div class="conf-foot-txt">Edge +8.3% · 6 algorithmes convergents · Signal Fort · Mise Kelly : 3.2% du capital</div>
      </div>
    </div>
  </div>
</section>

<!-- RADAR -->
<section class="section" id="radar" style="background:linear-gradient(180deg,transparent,rgba(124,58,237,.03) 50%,transparent);">
  <div class="si">
    <div class="s-tag">Radar de décision</div>
    <h2 class="s-title">Pourquoi <em>ces matchs</em> ?</h2>
    <p class="s-desc">La transparence est notre engagement. Voici pourquoi le moteur a sélectionné ces opportunités.</p>
    <div class="radar-layout">
      <div class="radar-wrap"><canvas id="rdr" width="340" height="340"></canvas></div>
      <div class="reasons" id="reasons">
        <div class="rsn"><div class="rsn-num">1</div><div><div class="rsn-title">Edge mathématique</div><div class="rsn-desc">La probabilité réelle calculée par Dixon-Coles dépasse la cote implicite de +8.3%. Avantage brut, mesurable, répétable sur le long terme.</div></div></div>
        <div class="rsn"><div class="rsn-num">2</div><div><div class="rsn-title">Convergence algorithmique</div><div class="rsn-desc">Les 6 algorithmes convergent vers le même résultat. Cette unanimité mathématique est statistiquement très significative et rare.</div></div></div>
        <div class="rsn"><div class="rsn-num">3</div><div><div class="rsn-title">9 facteurs au vert</div><div class="rsn-desc">Avantage domicile, rotation minimale, motivation maximale. Les 9 indicateurs contextuels valident simultanément le signal.</div></div></div>
        <div class="rsn"><div class="rsn-num">4</div><div><div class="rsn-title">Kelly adaptatif</div><div class="rsn-desc">Mise optimale de 3.2% calculée par Kelly. Risque strictement contrôlé, rendement mathématiquement optimisé sur la durée.</div></div></div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-sec" id="cta">
  <div class="cta-bg1"></div>
  <div class="cta-bg2"></div>
  <div class="cta-bg3"></div>
  <div class="cta-grid"></div>
  <div class="cta-inner">
    <div class="s-tag" style="margin-bottom:24px;">Commencer maintenant</div>
    <h2 class="cta-title">L'avantage <em>algorithmique</em><br>commence ici.</h2>
    <p class="cta-desc">Rejoignez les analystes qui utilisent la technologie pour prendre de meilleures décisions. Pas de chance — de la data et de la précision.</p>
    <button class="cta-btn">
      <span>⚡</span><span>Scanner les matchs maintenant</span>
    </button>
    <p class="cta-note">Pariez responsablement · 18+ uniquement · Aucune garantie de gain<br>EDGE Scanner n'est pas un conseil financier ou d'investissement</p>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-logo">EDGE <em>Scanner</em></div>
    <div class="footer-links">
      <a class="footer-link" href="#">Mentions légales</a>
      <a class="footer-link" href="#">CGU</a>
      <a class="footer-link" href="#">Confidentialité</a>
      <a class="footer-link" href="#">Contact</a>
    </div>
    <div class="footer-copy">© 2025 EDGE Scanner · Technologie Dixon-Coles & Bayésienne · 18+</div>
  </div>
</footer>

<script>
/* CURSOR */
var cr=document.getElementById('cur-ring'),cd=document.getElementById('cur-dot'),mx=0,my=0,ox=0,oy=0;
document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;cd.style.left=mx+'px';cd.style.top=my+'px';});
(function tick(){ox+=(mx-ox)*.14;oy+=(my-oy)*.14;cr.style.left=ox+'px';cr.style.top=oy+'px';requestAnimationFrame(tick);})();
document.querySelectorAll('button,a,.mbar-item,.algo,.step,.rsn,.card').forEach(function(el){
  el.addEventListener('mouseenter',function(){cr.style.width='40px';cr.style.height='40px';cr.style.borderColor='rgba(124,58,237,.8)';cr.style.boxShadow='0 0 14px rgba(124,58,237,.3)';});
  el.addEventListener('mouseleave',function(){cr.style.width='22px';cr.style.height='22px';cr.style.borderColor='rgba(124,58,237,.6)';cr.style.boxShadow='none';});
});

/* AMBIENT CANVAS — subtle nodes & particles only */
(function(){
  var cv=document.getElementById('canvas'),ctx=cv.getContext('2d'),W,H;
  function resize(){W=cv.width=innerWidth;H=cv.height=innerHeight;}
  resize();addEventListener('resize',resize);

  var G=72,nodes=[];
  for(var x=0;x<2400;x+=G)for(var y=0;y<1600;y+=G)
    nodes.push({x:x,y:y,a:.007+Math.random()*.042,ph:Math.random()*Math.PI*2,sp:.004+Math.random()*.008});

  var pts=[];
  for(var i=0;i<70;i++)
    pts.push({x:Math.random()*2400,y:Math.random()*1600,vx:(Math.random()-.5)*.12,vy:(Math.random()-.5)*.12,r:.4+Math.random()*.6,a:.018+Math.random()*.055,c:'124,58,237'});

  var trs=[];
  function mkT(){return{x:Math.random()*W,y:Math.random()*H,len:28+Math.random()*90,h:Math.random()>.5,prog:Math.random()*50,spd:.18+Math.random()*.28,a:.025+Math.random()*.05};}
  for(var j=0;j<35;j++)trs.push(mkT());

  var mX=-999,mY=-999;
  document.addEventListener('mousemove',function(e){mX=e.clientX;mY=e.clientY;});

  function frame(){
    ctx.clearRect(0,0,W,H);

    /* Subtle grid */
    ctx.strokeStyle='rgba(124,58,237,0.018)';ctx.lineWidth=1;
    for(var x=0;x<W;x+=G){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
    for(var y=0;y<H;y+=G){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}

    /* Nodes — magnetic */
    nodes.forEach(function(n){
      n.ph+=n.sp;
      var nx=n.x%W,ny=n.y%H;
      var dx=mX-nx,dy=mY-ny,dist=Math.sqrt(dx*dx+dy*dy);
      var pull=Math.max(0,1-dist/220)*.65;
      var a=n.a*(Math.sin(n.ph)*.45+.55)+pull*.22;
      ctx.beginPath();ctx.arc(nx+dx*pull*.03,ny+dy*pull*.03,1.1+pull*.7,0,Math.PI*2);
      ctx.fillStyle='rgba(124,58,237,'+a+')';ctx.fill();
    });

    /* Mouse glow — subtle */
    if(mX>0){
      var g=ctx.createRadialGradient(mX,mY,0,mX,mY,90);
      g.addColorStop(0,'rgba(124,58,237,0.035)');g.addColorStop(1,'transparent');
      ctx.fillStyle=g;ctx.fillRect(mX-90,mY-90,180,180);
    }

    /* Traces */
    trs.forEach(function(t){
      t.prog+=t.spd;var dr=Math.min(t.prog,t.len);
      ctx.beginPath();
      if(t.h){ctx.moveTo(t.x,t.y);ctx.lineTo(t.x+dr,t.y);}
      else{ctx.moveTo(t.x,t.y);ctx.lineTo(t.x,t.y+dr);}
      ctx.strokeStyle='rgba(124,58,237,'+t.a+')';ctx.lineWidth=1;ctx.stroke();
      if(t.prog>=t.len){
        var ex=t.h?t.x+t.len:t.x,ey=t.h?t.y:t.y+t.len;
        ctx.beginPath();ctx.arc(ex,ey,2,0,Math.PI*2);ctx.fillStyle='rgba(124,58,237,.35)';ctx.fill();
        ctx.beginPath();ctx.arc(ex,ey,5,0,Math.PI*2);ctx.fillStyle='rgba(124,58,237,.07)';ctx.fill();
      }
      if(t.prog>t.len+70)Object.assign(t,mkT());
    });

    /* Particles */
    pts.forEach(function(p){
      p.x+=p.vx;p.y+=p.vy;
      if(p.x<0)p.x=W;if(p.x>W)p.x=0;if(p.y<0)p.y=H;if(p.y>H)p.y=0;
      var dx=mX-p.x,dy=mY-p.y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<120){p.x+=dx*.0006;p.y+=dy*.0006;}
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle='rgba('+p.c+','+p.a+')';ctx.fill();
    });

    requestAnimationFrame(frame);
  }
  frame();
})();

/* COUNTERS */
function countTo(el,v,s,d){var c=0,step=v/(d/16),t=setInterval(function(){c=Math.min(c+step,v);el.textContent=Math.round(c)+s;if(c>=v)clearInterval(t);},16);}
setTimeout(function(){
  countTo(document.getElementById('m1'),247,'',1300);
  countTo(document.getElementById('m2'),18,'',1500);
  countTo(document.getElementById('m3'),73,'%',1700);
  countTo(document.getElementById('m4'),6,'%',1900);
},350);

/* CONFIDENCE */
var cwDone=false;
new IntersectionObserver(function(e){e.forEach(function(en){if(en.isIntersecting&&!cwDone){cwDone=true;
  var bar=document.getElementById('cwBar'),num=document.getElementById('cwNum'),c=0;
  var t=setInterval(function(){c=Math.min(c+.68,85);bar.style.width=c+'%';num.textContent=Math.round(c)+'%';if(c>=85)clearInterval(t);},18);
}});},{threshold:.4}).observe(document.querySelector('.conf-box'));

/* MATCH CARDS */
var MATCHES=[
  {league:'Ligue 1',flag:'FR',home:'PSG',away:'Monaco',time:"LIVE 78'",odds:[1.65,4.00,6.20],vi:0,conf:89,edge:12.4,live:true,score:'2–1'},
  {league:'Premier League',flag:'ENG',home:'Arsenal',away:'Man City',time:'21:00',odds:[2.60,3.10,2.70],vi:2,conf:65,edge:5.9,live:false,hot:true},
  {league:'La Liga',flag:'ES',home:'Atlético',away:'Villarreal',time:'20:00',odds:[1.88,3.50,4.10],vi:0,conf:68,edge:6.7,live:false,hot:true},
  {league:'Champions',flag:'UCL',home:'Bayern',away:'Inter Milan',time:'21:00',odds:[1.85,3.60,4.20],vi:-1,conf:61,edge:3.8,live:false,hot:false},
  {league:'Bundesliga',flag:'DE',home:'Dortmund',away:'Leverkusen',time:'18:30',odds:[2.40,3.20,3.00],vi:-1,conf:55,edge:2.1,live:false,hot:false},
  {league:'Serie A',flag:'IT',home:'Napoli',away:'Juventus',time:'20:45',odds:[2.10,3.30,3.50],vi:0,conf:70,edge:7.2,live:false,hot:true}
];
var OL=['1','N','2'];
document.getElementById('mgrid').innerHTML=MATCHES.map(function(m,i){
  var isHot=m.live||m.hot;
  var odds=m.odds.map(function(o,j){
    var v=isHot&&j===m.vi;
    return '<div class="odd'+(v?' odd-v':'')+'"><div class="odd-lbl">'+OL[j]+'</div><div class="odd-num">'+o.toFixed(2)+'</div></div>';
  }).join('');
  var ctr=m.live
    ?'<div class="card-ctr"><div class="card-score">'+m.score+'</div></div>'
    :'<div class="card-ctr"><div class="card-vsep"></div><div class="card-vs">vs</div><div class="card-vsep"></div></div>';
  return '<div class="card'+(m.live?' card-live':isHot?' card-hot':'')+'" style="animation:up .5s '+(i*.07)+'s ease both;opacity:0">'
    +'<div class="card-inner-glow"></div>'
    +'<div class="card-topbar '+(m.live?'ctb-live':isHot?'ctb-hot':'ctb-norm')+'"></div>'
    +'<div class="card-body">'
    +'<div class="card-hdr"><div class="mbar-flag f'+m.flag+'">'+m.flag+'</div><div class="card-lg">'+m.league+'</div>'
    +(m.live?'<div class="live-pill"><div class="live-pill-dot"></div>LIVE</div>':'')
    +'<div class="card-time">'+m.time+'</div>'
    +(isHot&&!m.live?'<div class="val-pill">+'+m.edge+'% edge</div>':'')
    +(m.live?'<div class="val-pill">+'+m.edge+'% edge</div>':'')
    +'</div>'
    +'<div class="card-teams"><div class="card-home">'+m.home+'</div>'+ctr+'<div class="card-away">'+m.away+'</div></div>'
    +'<div class="card-odds">'+odds+'</div>'
    +'<div class="card-foot"><div class="card-conf"><div class="card-conf-n">'+m.conf+'%</div><div class="card-conf-bar"><div class="card-conf-fill" style="width:'+m.conf+'%"></div></div></div>'
    +(isHot?'<div class="card-edge-tag">+'+m.edge+'% edge</div>':'')
    +'</div></div></div>';
}).join('');

function runScan(){
  var t=document.getElementById('scanTxt');
  t.textContent='Analyse en cours…';
  setTimeout(function(){t.textContent='✓  4 value bets confirmés';},1800);
}

/* RADAR */
(function(){
  var cv=document.getElementById('rdr');if(!cv)return;
  var ctx=cv.getContext('2d'),CX=170,CY=170,R=138;
  var LABS=['Edge','Consensus','Domicile','Forme','Motivation','Valeur'];
  var VALS=[.83,.78,.85,.70,.90,.75];
  var ANGS=LABS.map(function(_,i){return i/LABS.length*Math.PI*2-Math.PI/2;});
  var done=false;

  function render(p){
    ctx.clearRect(0,0,340,340);
    for(var r=1;r<=5;r++){
      var rr=R*r/5;
      ctx.beginPath();ANGS.forEach(function(a,i){var x=CX+Math.cos(a)*rr,y=CY+Math.sin(a)*rr;i?ctx.lineTo(x,y):ctx.moveTo(x,y);});
      ctx.closePath();ctx.strokeStyle=r===5?'rgba(124,58,237,.22)':'rgba(124,58,237,.07)';ctx.lineWidth=r===5?1.5:1;ctx.stroke();
    }
    ANGS.forEach(function(a){ctx.beginPath();ctx.moveTo(CX,CY);ctx.lineTo(CX+Math.cos(a)*R,CY+Math.sin(a)*R);ctx.strokeStyle='rgba(124,58,237,.09)';ctx.lineWidth=1;ctx.stroke();});
    ctx.beginPath();ANGS.forEach(function(a,i){var rr=R*VALS[i]*p,x=CX+Math.cos(a)*rr,y=CY+Math.sin(a)*rr;i?ctx.lineTo(x,y):ctx.moveTo(x,y);});
    ctx.closePath();
    var grd=ctx.createRadialGradient(CX,CY,0,CX,CY,R);
    grd.addColorStop(0,'rgba(124,58,237,.2)');grd.addColorStop(1,'rgba(124,58,237,.03)');
    ctx.fillStyle=grd;ctx.fill();
    ctx.strokeStyle='rgba(159,95,255,.9)';ctx.lineWidth=2;ctx.stroke();
    ANGS.forEach(function(a,i){
      var rr=R*VALS[i]*p,x=CX+Math.cos(a)*rr,y=CY+Math.sin(a)*rr;
      ctx.beginPath();ctx.arc(x,y,11,0,Math.PI*2);ctx.fillStyle='rgba(124,58,237,.1)';ctx.fill();
      ctx.beginPath();ctx.arc(x,y,5,0,Math.PI*2);ctx.fillStyle='rgba(159,95,255,.4)';ctx.fill();
      ctx.beginPath();ctx.arc(x,y,3,0,Math.PI*2);ctx.fillStyle='#9F5FFF';ctx.fill();
      ctx.beginPath();ctx.arc(x,y,1.5,0,Math.PI*2);ctx.fillStyle='#fff';ctx.fill();
    });
    ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.font='500 8.5px JetBrains Mono';ctx.fillStyle='rgba(82,82,91,.9)';
    ANGS.forEach(function(a,i){ctx.fillText(LABS[i],CX+Math.cos(a)*(R+22),CY+Math.sin(a)*(R+22));});
  }

  new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting&&!done){
        done=true;
        var st=null;
        (function anim(ts){if(!st)st=ts;var p=Math.min((ts-st)/880,1);render(p);if(p<1)requestAnimationFrame(anim);})();
        document.querySelectorAll('.rsn').forEach(function(el,i){setTimeout(function(){el.classList.add('in');},140+i*110);});
      }
    });
  },{threshold:.25}).observe(cv);
  render(0);
})();
</script>
</body>
</html>

