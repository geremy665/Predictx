{
  "version": 2,
  "functions": {
    "api/matches.js": { "runtime": "nodejs18.x" },
    "api/chat.js": { "runtime": "nodejs18.x" },
    "api/standings.js": { "runtime": "nodejs18.x" },
    "api/history.js": { "runtime": "nodejs18.x" },
    "api/odds.js": { "runtime": "nodejs18.x" }
  },
  "rewrites": [
